{
  "name": "caderno-de-plantao",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Caderno de Plantão — Motor narrativo interativo para light novel clínica",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "validate": "tsx --tsconfig tsconfig.scripts.json scripts/validate-case.ts"
  },
  "dependencies": {
    "preact": "^10.29.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^3.0.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.0.0",
    "fast-check": "^3.23.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^3.0.0"
  }
}
